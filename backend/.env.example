# 服务器配置
# 监听端口（默认：3001）
PORT=3001

# 绑定地址（默认：0.0.0.0，表示所有网络接口）
HOSTNAME=0.0.0.0

# 运行环境（development | production）
NODE_ENV=production

# 可信反向代理 IP，逗号分隔。默认空值时不信任 X-Forwarded-For，避免客户端伪造 IP 绕过限流。
# 仅在前面部署了 Nginx / 网关 / Tunnel 且需要按真实客户端 IP 限流时填写，例如：127.0.0.1,172.18.0.1
RKAPI_IMAGE_TRUSTED_PROXY_IPS=

# SQLite 数据库文件路径（Docker 部署默认挂载到 ./data）
RKAPI_IMAGE_TASK_DB=/app/backend/data/rkapi-tasks.sqlite

# 生成图片文件目录（Docker 部署默认挂载到 ./data）
RKAPI_IMAGE_IMAGE_DIR=/app/backend/data/rkapi-images

# 最大并发图片数
RKAPI_IMAGE_TASK_CONCURRENCY=50

# ============================================
# 队列与限流配置（运行时读取，修改 .env 后通常无需重启）
# ============================================

# 全局最大待处理任务数（排队中 + 生成中），达到后返回 503 QUEUE_FULL
RKAPI_IMAGE_MAX_QUEUE_SIZE=200

# 限流窗口长度（毫秒）
RKAPI_IMAGE_RATE_LIMIT_WINDOW_MS=60000

# 单 IP 在一个窗口内最多创建多少个任务，超过返回 429 RATE_LIMITED
RKAPI_IMAGE_RATE_LIMIT_MAX_REQUESTS_PER_IP=10

# 单 API Key 在一个窗口内最多创建多少个任务，超过返回 429 RATE_LIMITED
RKAPI_IMAGE_RATE_LIMIT_MAX_REQUESTS_PER_API_KEY=10

# 单 IP 最多同时拥有多少个待处理任务，超过返回 429 TOO_MANY_PENDING_TASKS
RKAPI_IMAGE_MAX_PENDING_TASKS_PER_IP=20

# 单 API Key 最多同时拥有多少个待处理任务，超过返回 429 TOO_MANY_PENDING_TASKS
RKAPI_IMAGE_MAX_PENDING_TASKS_PER_API_KEY=20

# 队列满/限流时返回给客户端的 Retry-After 秒数
RKAPI_IMAGE_RATE_LIMIT_RETRY_AFTER_SECONDS=60

# ============================================
# 上游 Base URL 内网改写（运行时读取）
# ============================================

# 前端模型 Base URL 固定保存为 https://api.rkai6.com；后端实际请求时按这里改写为 Docker 内网地址，适合 1Panel / Docker 内部访问 new-api，避免 Cloudflare/Nginx 504。
# 支持多个映射。JSON 对象格式示例：
# RKAPI_IMAGE_BASE_URL_REWRITE_MAP={"https://api.rkai6.com":"http://new-api:3000","https://api.example.com":"http://example-new-api:3000"}
RKAPI_IMAGE_BASE_URL_REWRITE_MAP=

# ============================================
# 上游请求服务标识（运行时读取）
# ============================================

# 所有上游请求携带的稳定 User-Agent。请填写部署方真实、可追溯的服务标识，不要伪造浏览器或第三方服务身份。
RKAPI_IMAGE_OUTBOUND_USER_AGENT=

# ============================================
# 平台品牌（运行时读取）
# ============================================

# 页面标题、Header 名称与 PWA 名称。修改后刷新页面即可生效。
RKAPI_IMAGE_PLATFORM_NAME=RKAPI Image

# Header Logo。仅允许站内绝对路径或 HTTP(S) URL。如:./logo.png 或 https://example.com/logo.png
RKAPI_IMAGE_PLATFORM_LOGO_URL=/favicon.png

# 浏览器 favicon 与 PWA 图标。仅允许站内绝对路径或 HTTP(S) URL。
RKAPI_IMAGE_PLATFORM_ICON_URL=/favicon.png

# PWA 安装图标。建议提供真实 192x192、512x512 和 maskable 512x512 PNG；为空时使用内置图标。
RKAPI_IMAGE_PLATFORM_ICON_192_URL=/icon-192.png
RKAPI_IMAGE_PLATFORM_ICON_512_URL=/icon-512.png
RKAPI_IMAGE_PLATFORM_MASKABLE_ICON_URL=/icon-maskable-512.png

# ============================================
# 图片模型 API Key 指引（设置页展示，运行时读取）
# ============================================

RKAPI_IMAGE_IMAGE_MODEL_KEY_GUIDE_TITLE=还没有图片模型 API Key？
RKAPI_IMAGE_IMAGE_MODEL_KEY_GUIDE_DESCRIPTION=默认已为你准备 RKAPI 图片模型，填入 API Key 后保存即可开始生成图片。
RKAPI_IMAGE_IMAGE_MODEL_KEY_GUIDE_CTA_LABEL=打开 RKAPI
RKAPI_IMAGE_IMAGE_MODEL_KEY_GUIDE_URL=https://api.rkai6.com

# ============================================
# 首次图片模型默认配置（运行时读取）
# ============================================

# 仅影响没有浏览器本地模型配置的新用户；API Key 由用户在设置页填写，不通过环境变量下发。
# 默认使用 gpt-image-2；用户仍可在设置页按实际网关模型 ID 修改。
RKAPI_IMAGE_DEFAULT_IMAGE_MODEL_MODEL_ID=gpt-image-2
RKAPI_IMAGE_DEFAULT_IMAGE_MODEL_MAX_REF_IMAGES=16
RKAPI_IMAGE_DEFAULT_IMAGE_MODEL_SUPPORTS_ADVANCED_PARAMS=true
# 仅 OpenAI GPT Image 2 预设有效，默认开启。
RKAPI_IMAGE_DEFAULT_IMAGE_MODEL_STREAM_IMAGES=true

# ============================================
# 图片模板模型 ID 预设（可选）
# ============================================

# JSON 对象，键为内置模板 ID，值为实际调用的模型 ID。按需修改右侧模型 ID。
RKAPI_IMAGE_IMAGE_PRESET_MODEL_IDS={"gemini-2.5-flash-image":"gemini-2.5-flash-image","gemini-3-pro-image-preview":"gemini-3-pro-image-preview","gemini-3.1-flash-image-preview":"gemini-3.1-flash-image-preview","gemini-3.1-flash-lite-image":"gemini-3.1-flash-lite-image","gpt-image-2":"gpt-image-2","grok-imagine-image":"grok-imagine-image","grok-imagine-image-quality":"grok-imagine-image-quality"}

# ============================================
# 提示词广场配置
# ============================================

# 提示词广场模式：1=常驻（直接显示） 2=私密（需密码验证，点七下标题） 3=关闭（完全隐藏）
# 修改 .env 文件后实时生效，无需重启服务
PROMPT_GALLERY_MODE=1
PROMPT_GALLERY_PASSWORD=
